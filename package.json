{
  "name": "juno-bot",
  "version": "1.0.0",
  "description": "meow",
  "license": "ISC",
  "author": "shirley and jon",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "check-format": "npx prettier . --check",
    "apply-format": "npx prettier . --write",
    "clean": "rm -rf node_modules package-lock.json dist",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
